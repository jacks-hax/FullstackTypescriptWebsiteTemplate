    "scripts": {
        "test": "echo \"Error: no test specified\" && exit 1",
        "configure": "npm run configure:environment && npm run configure:database",
        "configure:environment": "node bin/configure-environment.ts",
        "configure:database": "node bin/configure-database.ts",
        "build": "gulp",
        "build:server": "gulp --stack server",
        "build:client": "gulp --stack client",
        "server": "node --env-file=./dist/.env ./dist/server/index.js",
        "server:admin": "node --env-file=./dist/.env ./dist/server/admin/index.js",
        "parsejwt": "node bin/parse-jwt.js",
        "start": "npm run build && npm run server",
        "start:admin": "npm run build && npm run server:admin"
    },
